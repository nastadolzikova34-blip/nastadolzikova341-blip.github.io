@{
    ViewData["Title"] = "Мой профиль";
    Layout = null;
}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Мой профиль - Совместный просмотр</title>

    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

    <style>
        body {
            background: linear-gradient(135deg, #8b0000 0%, #000000 60%);
            min-height: 100vh;
            font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', 'Helvetica Neue', sans-serif;
        }

        .profile-container {
            min-height: 100vh;
            padding: 40px 20px;
        }

        .profile-card {
            background: #000000;
            border-radius: 5px;
            box-shadow: 0 15px 35px #8b0000;
            padding: 40px;
            max-width: 800px;
            margin: 0 auto;
            border: none;
        }

        .avatar-container {
            position: relative;
            width: 150px;
            height: 150px;
            margin: 0 auto 20px;
        }

        .avatar-image {
            width: 100%;
            height: 100%;
            border-radius: 50%;
            border: 4px solid #8b0000;
            object-fit: cover;
            background: linear-gradient(135deg, #333333 0%, #1a1a1a 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 60px;
            color: #8b0000;
        }

        .avatar-upload {
            position: absolute;
            bottom: 5px;
            right: 5px;
            background: #8b0000;
            border: none;
            border-radius: 50%;
            width: 40px;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: transform 0.3s;
            color: white;
        }

            .avatar-upload:hover {
                transform: scale(1.1);
                background: #660000;
            }

        #avatarInput {
            display: none;
        }

        .form-control, .form-control:focus {
            background: #1a1a1a;
            border: 1px solid #8b0000;
            color: white;
            box-shadow: none;
        }

            .form-control::placeholder {
                color: #666;
            }

        .form-label {
            color: #8b0000;
            font-weight: 500;
        }

        .btn-save {
            background: linear-gradient(135deg, #8b0000 0%, #000000 50%);
            border: none;
            color: white;
            padding: 12px 30px;
            transition: transform 0.3s;
            width: 100%;
        }

            .btn-save:hover {
                transform: translateY(-2px);
                box-shadow: 0 5px 15px #8b0000;
                color: white;
            }

        .post-card {
            background: linear-gradient(135deg, #1a1a1a 0%, #000000 100%);
            border: 1px solid #8b0000;
            border-radius: 5px;
            padding: 15px;
            margin-bottom: 15px;
        }

        .post-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 10px;
            color: #8b0000;
        }

        .post-date {
            font-size: 0.8rem;
            color: #666;
        }

        .post-content {
            color: white;
            margin-bottom: 10px;
        }

        .post-actions {
            display: flex;
            gap: 10px;
            justify-content: flex-end;
        }

        .btn-post-action {
            background: none;
            border: 1px solid #8b0000;
            color: #8b0000;
            padding: 5px 15px;
            border-radius: 5px;
            transition: all 0.3s;
        }

            .btn-post-action:hover {
                background: #8b0000;
                color: white;
            }

        .stats-card {
            background: linear-gradient(135deg, #8b0000 0%, #000000 50%);
            border-radius: 5px;
            padding: 15px;
            text-align: center;
            color: white;
        }

        .stats-number {
            font-size: 2rem;
            font-weight: bold;
            color: #ffffff;
        }

        .guest-badge {
            background: #333333;
            color: #8b0000;
            padding: 5px 15px;
            border-radius: 20px;
            display: inline-block;
            border: 1px solid #8b0000;
        }

        .alert-message {
            position: fixed;
            top: 20px;
            right: 20px;
            z-index: 9999;
            min-width: 300px;
        }
    </style>
</head>
<body>
    <div class="profile-container">
        <div class="profile-card">
            <!-- Шапка профиля -->
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="text-white m-0">
                    <i class="fas fa-user-circle me-2 text-danger"></i>Мой профиль
                </h2>
                <div>
                    <a href="/" class="btn btn-outline-light me-2">
                        <i class="fas fa-home me-1"></i>Главная
                    </a>
                    <button class="btn btn-outline-danger" onclick="logout()">
                        <i class="fas fa-sign-out-alt me-1"></i>Выйти
                    </button>
                </div>
            </div>

            <!-- Информация о пользователе -->
            <div id="guestWarning" class="alert alert-warning mb-4" style="display: none;">
                <i class="fas fa-info-circle me-2"></i>
                Вы вошли как гость. <a href="/Home/Login" class="alert-link">Зарегистрируйтесь</a>, чтобы создать полноценный профиль.
            </div>

            <!-- Аватар и основная информация -->
            <div class="row mb-4">
                <div class="col-md-4 text-center">
                    <div class="avatar-container">
                        <div id="avatarPreview" class="avatar-image">
                            <i class="fas fa-user-circle"></i>
                        </div>
                        <label for="avatarInput" class="avatar-upload" title="Загрузить фото">
                            <i class="fas fa-camera"></i>
                        </label>
                        <input type="file" id="avatarInput" accept="image/*" onchange="previewAvatar(event)">
                    </div>
                </div>
                <div class="col-md-8">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Логин</label>
                            <input type="text" class="form-control" id="username" readonly>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Никнейм</label>
                            <input type="text" class="form-control" id="nickname" placeholder="Введите никнейм">
                        </div>
                    </div>
                </div>
            </div>

            <!-- О себе -->
            <div class="mb-4">
                <label class="form-label">О себе</label>
                <textarea class="form-control" id="bio" rows="3" placeholder="Расскажите о себе..."></textarea>
            </div>

            <!-- Кнопка сохранения -->
            <button class="btn btn-save mb-4" onclick="saveProfile()">
                <i class="fas fa-save me-2"></i>Сохранить изменения
            </button>

            <!-- Статистика (только для зарегистрированных) -->
            <div id="statsSection" style="display: none;">
                <h4 class="text-white mb-3">
                    <i class="fas fa-chart-bar me-2 text-danger"></i>Статистика
                </h4>
                <div class="row g-3 mb-4">
                    <div class="col-md-4">
                        <div class="stats-card">
                            <i class="fas fa-calendar-alt mb-2"></i>
                            <div class="stats-number" id="regDate">-</div>
                            <div>Дата регистрации</div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="stats-card">
                            <i class="fas fa-pen mb-2"></i>
                            <div class="stats-number" id="postsCount">0</div>
                            <div>Всего постов</div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="stats-card">
                            <i class="fas fa-clock mb-2"></i>
                            <div class="stats-number" id="lastActive">-</div>
                            <div>Последний вход</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Посты пользователя -->
            <div>
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h4 class="text-white m-0">
                        <i class="fas fa-newspaper me-2 text-danger"></i>Мои посты
                    </h4>
                    <button class="btn btn-danger btn-sm" onclick="showAddPostModal()">
                        <i class="fas fa-plus me-1"></i>Новый пост
                    </button>
                </div>

                <!-- Контейнер для постов -->
                <div id="postsContainer">
                    <div class="text-center text-white-50 py-4">
                        <i class="fas fa-inbox fa-3x mb-3"></i>
                        <p>У вас пока нет постов</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Модальное окно для добавления/редактирования поста -->
    <div class="modal fade" id="postModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content" style="background: #000000; border: 2px solid #8b0000;">
                <div class="modal-header" style="border-bottom: 1px solid #8b0000;">
                    <h5 class="modal-title text-white" id="postModalTitle">Новый пост</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" id="editingPostId">
                    <div class="mb-3">
                        <label class="form-label">Заголовок</label>
                        <input type="text" class="form-control" id="postTitle" placeholder="Введите заголовок">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Содержание</label>
                        <textarea class="form-control" id="postContent" rows="5" placeholder="Что у вас нового?"></textarea>
                    </div>
                </div>
                <div class="modal-footer" style="border-top: 1px solid #8b0000;">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Отмена</button>
                    <button type="button" class="btn btn-danger" onclick="savePost()">Сохранить</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Контейнер для уведомлений -->
    <div id="alertContainer" class="alert-message"></div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        let currentUser = null;
        let postModal = null;

        // Показать уведомление
        function showAlert(message, type = 'success') {
            const alertContainer = document.getElementById('alertContainer');
            const alertDiv = document.createElement('div');
            alertDiv.className = `alert alert-${type} alert-dismissible fade show`;
            alertDiv.role = 'alert';
            alertDiv.innerHTML = `
                ${message}
                <button type="button" class="btn-close" onclick="this.parentElement.remove()"></button>
            `;
            alertContainer.appendChild(alertDiv);

            setTimeout(() => {
                if (alertDiv.parentElement) {
                    alertDiv.remove();
                }
            }, 3000);
        }

        // Загрузка данных пользователя
        function loadUserData() {
            const userData = localStorage.getItem('currentUser');

                   if (!userData) {
            window.location.href = '/Account/Login';  
            return;
        }

            currentUser = JSON.parse(userData);

            // Заполняем форму
            document.getElementById('username').value = currentUser.username || '';
            document.getElementById('nickname').value = currentUser.nickname || currentUser.username || '';
            document.getElementById('bio').value = currentUser.bio || '';

            // Загружаем аватар
            if (currentUser.avatar) {
                const avatarPreview = document.getElementById('avatarPreview');
                avatarPreview.innerHTML = `<img src="${currentUser.avatar}" style="width: 100%; height: 100%; border-radius: 50%; object-fit: cover;">`;
            }

            // Показываем/скрываем секции для гостей
            if (currentUser.isGuest) {
                document.getElementById('guestWarning').style.display = 'block';
                document.getElementById('statsSection').style.display = 'none';
                document.querySelector('button[onclick="showAddPostModal()"]').disabled = true;
            } else {
                document.getElementById('guestWarning').style.display = 'none';
                document.getElementById('statsSection').style.display = 'block';

                // Загружаем статистику
                const users = JSON.parse(localStorage.getItem('registeredUsers') || '[]');
                const user = users.find(u => u.username === currentUser.username);

                if (user) {
                    document.getElementById('regDate').textContent = user.registrationDate ?
                        new Date(user.registrationDate).toLocaleDateString('ru-RU') : '-';
                    document.getElementById('lastActive').textContent =
                        new Date().toLocaleTimeString('ru-RU', { hour: '2-digit', minute: '2-digit' });
                }
            }

            // Загружаем посты
            loadPosts();
        }

        // Предпросмотр аватара
        function previewAvatar(event) {
            const file = event.target.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    const avatarPreview = document.getElementById('avatarPreview');
                    avatarPreview.innerHTML = `<img src="${e.target.result}" style="width: 100%; height: 100%; border-radius: 50%; object-fit: cover;">`;

                    // Сохраняем аватар во временную переменную
                    currentUser.tempAvatar = e.target.result;
                };
                reader.readAsDataURL(file);
            }
        }

        // Сохранение профиля
        function saveProfile() {
            if (!currentUser) return;

            // Обновляем данные
            currentUser.nickname = document.getElementById('nickname').value.trim() || currentUser.username;
            currentUser.bio = document.getElementById('bio').value.trim();

            if (currentUser.tempAvatar) {
                currentUser.avatar = currentUser.tempAvatar;
                delete currentUser.tempAvatar;
            }

            // Сохраняем в текущую сессию
            localStorage.setItem('currentUser', JSON.stringify(currentUser));

            // Если это зарегистрированный пользователь, обновляем данные в общем списке
            if (!currentUser.isGuest) {
                const users = JSON.parse(localStorage.getItem('registeredUsers') || '[]');
                const userIndex = users.findIndex(u => u.username === currentUser.username);

                if (userIndex !== -1) {
                    users[userIndex].nickname = currentUser.nickname;
                    users[userIndex].bio = currentUser.bio;
                    users[userIndex].avatar = currentUser.avatar;
                    localStorage.setItem('registeredUsers', JSON.stringify(users));
                }
            }

            // Обновляем имя в комнатах
            localStorage.setItem('watchTogetherUserName', currentUser.nickname);

            showAlert('Профиль успешно сохранен!', 'success');
        }

        // Загрузка постов
        function loadPosts() {
            if (currentUser.isGuest) {
                document.getElementById('postsContainer').innerHTML = `
                    <div class="text-center text-white-50 py-4">
                        <i class="fas fa-lock fa-3x mb-3"></i>
                        <p>Гости не могут создавать посты</p>
                    </div>
                `;
                return;
            }

            const users = JSON.parse(localStorage.getItem('registeredUsers') || '[]');
            const user = users.find(u => u.username === currentUser.username);

            if (user && user.posts && user.posts.length > 0) {
                document.getElementById('postsCount').textContent = user.posts.length;

                const postsHtml = user.posts.sort((a, b) =>
                    new Date(b.date) - new Date(a.date)
                ).map(post => `
                    <div class="post-card" data-post-id="${post.id}">
                        <div class="post-header">
                            <h5 class="m-0">${escapeHtml(post.title || 'Без заголовка')}</h5>
                            <span class="post-date">${new Date(post.date).toLocaleString('ru-RU')}</span>
                        </div>
                        <div class="post-content">
                            ${escapeHtml(post.content).replace(/\n/g, '<br>')}
                        </div>
                        <div class="post-actions">
                            <button class="btn-post-action" onclick="editPost('${post.id}')">
                                <i class="fas fa-edit"></i> Редактировать
                            </button>
                            <button class="btn-post-action" onclick="deletePost('${post.id}')">
                                <i class="fas fa-trash"></i> Удалить
                            </button>
                        </div>
                    </div>
                `).join('');

                document.getElementById('postsContainer').innerHTML = postsHtml;
            } else {
                document.getElementById('postsCount').textContent = '0';
                document.getElementById('postsContainer').innerHTML = `
                    <div class="text-center text-white-50 py-4">
                        <i class="fas fa-inbox fa-3x mb-3"></i>
                        <p>У вас пока нет постов</p>
                    </div>
                `;
            }
        }

        // Показать модальное окно добавления поста
        function showAddPostModal() {
            if (currentUser.isGuest) {
                showAlert('Гости не могут создавать посты', 'warning');
                return;
            }

            document.getElementById('postModalTitle').textContent = 'Новый пост';
            document.getElementById('editingPostId').value = '';
            document.getElementById('postTitle').value = '';
            document.getElementById('postContent').value = '';

            if (!postModal) {
                postModal = new bootstrap.Modal(document.getElementById('postModal'));
            }
            postModal.show();
        }

        // Редактирование поста
        function editPost(postId) {
            const users = JSON.parse(localStorage.getItem('registeredUsers') || '[]');
            const user = users.find(u => u.username === currentUser.username);
            const post = user.posts.find(p => p.id === postId);

            if (post) {
                document.getElementById('postModalTitle').textContent = 'Редактировать пост';
                document.getElementById('editingPostId').value = postId;
                document.getElementById('postTitle').value = post.title || '';
                document.getElementById('postContent').value = post.content || '';

                if (!postModal) {
                    postModal = new bootstrap.Modal(document.getElementById('postModal'));
                }
                postModal.show();
            }
        }

        // Сохранение поста
        function savePost() {
            const title = document.getElementById('postTitle').value.trim();
            const content = document.getElementById('postContent').value.trim();
            const editingId = document.getElementById('editingPostId').value;

            if (!content) {
                showAlert('Введите содержание поста', 'warning');
                return;
            }

            const users = JSON.parse(localStorage.getItem('registeredUsers') || '[]');
            const userIndex = users.findIndex(u => u.username === currentUser.username);

            if (userIndex !== -1) {
                if (!users[userIndex].posts) {
                    users[userIndex].posts = [];
                }

                if (editingId) {
                    // Редактирование существующего поста
                    const postIndex = users[userIndex].posts.findIndex(p => p.id === editingId);
                    if (postIndex !== -1) {
                        users[userIndex].posts[postIndex].title = title;
                        users[userIndex].posts[postIndex].content = content;
                        users[userIndex].posts[postIndex].editedDate = new Date().toISOString();
                        showAlert('Пост обновлен!', 'success');
                    }
                } else {
                    // Новый пост
                    const newPost = {
                        id: Date.now().toString(),
                        title: title,
                        content: content,
                        date: new Date().toISOString()
                    };
                    users[userIndex].posts.push(newPost);
                    showAlert('Пост создан!', 'success');
                }

                // Сохраняем изменения
                localStorage.setItem('registeredUsers', JSON.stringify(users));

                // Обновляем отображение
                loadPosts();

                // Закрываем модальное окно
                postModal.hide();
            }
        }

        // Удаление поста
        function deletePost(postId) {
            if (!confirm('Вы уверены, что хотите удалить этот пост?')) return;

            const users = JSON.parse(localStorage.getItem('registeredUsers') || '[]');
            const userIndex = users.findIndex(u => u.username === currentUser.username);

            if (userIndex !== -1) {
                users[userIndex].posts = users[userIndex].posts.filter(p => p.id !== postId);
                localStorage.setItem('registeredUsers', JSON.stringify(users));

                loadPosts();
                showAlert('Пост удален', 'success');
            }
        }

        // Выход из аккаунта
        function logout() {
            localStorage.removeItem('currentUser');

            // Оставляем имя для комнат как Гость
            localStorage.setItem('watchTogetherUserName', 'Гость_' + Math.floor(Math.random() * 10000));

            showAlert('Вы вышли из аккаунта', 'info');

            setTimeout(() => {
                window.location.href = '/';
            }, 1500);
        }

        // Экранирование HTML
        function escapeHtml(unsafe) {
            if (!unsafe) return '';
            return unsafe
                .replace(/&/g, "&amp;")
                .replace(/</g, "&lt;")
                .replace(/>/g, "&gt;")
                .replace(/"/g, "&quot;")
                .replace(/'/g, "&#039;");
        }

        // Инициализация
        document.addEventListener('DOMContentLoaded', loadUserData);
    </script>
</body>
</html>