@{
    ViewData["Title"] = "Главная";
    Layout = null;
}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Совместный просмотр видео</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

    <style>
        body {
            background: linear-gradient(135deg, #8b0000 0%, #000000 60%);
            min-height: 100vh;
            font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', 'Helvetica Neue', sans-serif;
            color: #000000;
            padding-top: 70px;
        }

        .navbar-custom {
            background: rgba(0, 0, 0, 0.9);
            backdrop-filter: blur(10px);
            border-bottom: 2px solid #8b0000;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 1000;
        }

        .navbar-brand {
            font-size: 1.5rem;
            font-weight: bold;
            color: white !important;
        }

            .navbar-brand i {
                color: #8b0000;
            }

        .btn-profile {
            background: linear-gradient(135deg, #8b0000 0%, #000000 50%);
            border: 1px solid #8b0000;
            color: white;
            padding: 8px 20px;
            border-radius: 5px;
            transition: all 0.3s;
        }

            .btn-profile:hover {
                transform: translateY(-2px);
                box-shadow: 0 5px 15px #8b0000;
                color: white;
            }

        .user-dropdown .dropdown-menu {
            background: #000000;
            border: 1px solid #8b0000;
        }

        .user-dropdown .dropdown-item {
            color: white;
            transition: all 0.3s;
        }

            .user-dropdown .dropdown-item:hover {
                background: #8b0000;
                color: white;
            }

        /* Основной контейнер — flex для двух колонок */
        .main-layout {
            display: flex;
            min-height: calc(100vh - 70px);
            padding: 20px;
            gap: 20px;
        }

        /* Левая часть — приветствие и создание комнаты */
        .left-content {
            flex: 1;
            min-width: 0;
        }

        .welcome-card {
            background: #000000;
            border-radius: 5px;
            box-shadow: 0 15px 35px #8b0000;
            padding: 40px;
            width: 100%;
            border: none;
        }

        /* Правая часть — лента активных комнат */
        .rooms-feed {
            width: 360px;
            background: rgba(0, 0, 0, 0.8);
            border-radius: 10px;
            border: 1px solid #8b0000;
            backdrop-filter: blur(10px);
            display: flex;
            flex-direction: column;
            max-height: calc(100vh - 110px);
            position: sticky;
            top: 90px;
        }

        .rooms-header {
            padding: 20px;
            border-bottom: 1px solid #8b0000;
            background: linear-gradient(135deg, #000000 0%, #8b0000 50%);
            border-radius: 10px 10px 0 0;
        }

            .rooms-header h4 {
                color: white;
                margin: 0;
                display: flex;
                align-items: center;
                gap: 10px;
            }

            .rooms-header i {
                color: #ffd700;
            }

        .rooms-list {
            flex: 1;
            overflow-y: auto;
            padding: 15px;
        }

        .room-card {
            background: linear-gradient(135deg, #1a0000 0%, #0a0a0a 100%);
            border: 1px solid #8b0000;
            border-radius: 10px;
            padding: 15px;
            margin-bottom: 12px;
            cursor: pointer;
            transition: all 0.3s;
        }

            .room-card:hover {
                transform: translateX(-5px);
                border-color: #ff4444;
                box-shadow: 0 5px 15px rgba(139, 0, 0, 0.5);
            }

        .room-title {
            display: flex;
            align-items: center;
            gap: 8px;
            color: white;
            font-weight: bold;
            margin-bottom: 8px;
        }

            .room-title i {
                color: #4CAF50;
                font-size: 10px;
            }

        .room-info {
            display: flex;
            justify-content: space-between;
            color: #aaa;
            font-size: 0.85rem;
            margin-bottom: 8px;
        }

        .room-users {
            display: flex;
            align-items: center;
            gap: 10px;
            color: #ccc;
            font-size: 0.85rem;
        }

            .room-users i {
                color: #8b0000;
            }

        .join-btn {
            background: linear-gradient(135deg, #8b0000 0%, #660000 100%);
            border: none;
            color: white;
            padding: 6px 15px;
            border-radius: 20px;
            font-size: 0.85rem;
            transition: all 0.3s;
        }

            .join-btn:hover {
                background: #ff4444;
                transform: scale(1.05);
            }

        .refresh-btn {
            background: none;
            border: 1px solid #8b0000;
            color: white;
            padding: 5px 12px;
            border-radius: 20px;
            font-size: 0.8rem;
            transition: all 0.3s;
        }

            .refresh-btn:hover {
                background: #8b0000;
            }

        .empty-rooms {
            text-align: center;
            color: #888;
            padding: 40px 20px;
        }

            .empty-rooms i {
                font-size: 3rem;
                color: #8b0000;
                margin-bottom: 15px;
            }

        .logo {
            font-size: 4rem;
            color: #8b0000;
            margin-bottom: 20px;
        }

        .btn-primary {
            background: linear-gradient(135deg, #8b0000 0%, #000000 50%);
            border: none;
            padding: 15px 30px;
            font-size: 1.1rem;
            border-radius: 5px;
            transition: transform 0.3s;
        }

            .btn-primary:hover {
                transform: translateY(-3px);
                box-shadow: 0 10px 20px #8b0000;
            }

        .btn-success {
            background: linear-gradient(135deg, #8b0000 0%, #000000 50%);
            border: none;
            padding: 15px 30px;
            font-size: 1.1rem;
            border-radius: 5px;
            transition: transform 0.3s;
        }

            .btn-success:hover {
                transform: translateY(-3px);
                box-shadow: 0 10px 20px #8b0000;
            }

        .feature-icon {
            font-size: 2.5rem;
            color: #8b0000;
            margin-bottom: 15px;
        }

        .feature-card {
            background: linear-gradient(135deg, #8b0000 0%, #000000 50%);
            border-radius: 5px;
            padding: 25px;
            height: 100%;
            border: 1px solid #ffffff;
            transition: transform 0.3s;
        }

            .feature-card:hover {
                transform: translateY(-5px);
                box-shadow: 0 10px 25px #8b0000;
            }

        .notification {
            position: fixed;
            top: 80px;
            right: 20px;
            z-index: 9999;
            min-width: 300px;
            animation: slideIn 0.3s ease;
        }

        @@keyframes slideIn {
            from {
                transform: translateX(100%);
                opacity: 0;
            }

            to {
                transform: translateX(0);
                opacity: 1;
            }
        }

        /* Адаптивность */
        @@media (max-width: 992px) {
            .main-layout {
                flex-direction: column;
            }

            .rooms-feed {
                width: 100%;
                position: static;
            }
        }

        @@media (max-width: 768px) {
            .main-layout

        {
            flex-direction: column !important;
        }

        .left-content,
        .rooms-feed {
            width: 100% !important;
        }

        .rooms-feed {
            position: static !important;
            max-height: none !important;
        }

        .welcome-card {
            padding: 20px !important;
        }

            .welcome-card h1 {
                font-size: 1.8rem !important;
            }

        .feature-card {
            margin-bottom: 10px;
            padding: 15px !important;
        }

        .feature-icon {
            font-size: 1.5rem !important;
        }

        .feature-card h5 {
            font-size: 1rem !important;
        }

        .feature-card p {
            font-size: 0.8rem !important;
        }

        }
    </style>
</head>
<body>
    <!-- Навигационная панель -->
    <nav class="navbar navbar-dark navbar-custom">
        <div class="container-fluid">
            <a href="/" class="navbar-brand">
                <i class="fas fa-film me-2"></i>
                Смотрим вместе
            </a>
            <div class="d-flex align-items-center">
                <div id="userMenu" class="d-flex align-items-center">
                    <div class="spinner-border spinner-border-sm text-danger" role="status">
                        <span class="visually-hidden">Загрузка...</span>
                    </div>
                </div>
            </div>
        </div>
    </nav>

    <!-- Основной контент — две колонки -->
    <div class="main-layout">
        <!-- Левая часть -->
        <div class="left-content">
            <div class="welcome-card">
                <div class="text-center mb-5">
                    <div class="logo">
                        <i class="fas fa-film"></i>
                    </div>
                    <h1 class="display-4 fw-bold mb-3" style="color: #ffffff;">
                        Смотрим вместе
                    </h1>
                    <p class="lead text-white mb-4">
                        Создавайте комнаты для совместного просмотра видео с друзьями.<br>
                        Поддерживается VK Video и RuTube.
                    </p>
                </div>

                <!-- Форма создания/входа в комнату -->
                <div class="card mb-5 text-white" style="background: linear-gradient(135deg, #000000 0%,#8b0000 50%);">
                    <div class="card-body p-4">
                        <h5 class="card-title mb-3">
                            <i class="fas fa-door-open me-2"></i>Создать или войти в комнату
                        </h5>

                        <form action="/Home/Room" method="get" class="mb-4">
                            <div class="mb-3">
                                <label for="roomId" class="form-label">
                                    <i class="fas fa-key me-1"></i>ID комнаты (оставьте пустым для новой):
                                </label>
                                <input type="text" class="form-control form-control-lg" id="roomId" name="id"
                                       placeholder="например: movie-night-123"
                                       style="background: #1a1a1a; border: 1px solid #8b0000; color: white;">
                            </div>

                            <div class="d-grid gap-3">
                                <button type="submit" class="btn btn-primary btn-lg">
                                    <i class="fas fa-sign-in-alt me-2"></i>Присоединиться к комнате
                                </button>

                                <a href="/Home/Room" class="btn btn-success btn-lg">
                                    <i class="fas fa-plus-circle me-2"></i>Создать новую комнату
                                </a>
                            </div>
                        </form>

                        <div class="alert mb-0" style="background: linear-gradient(135deg, #8b0000 0%, #000000 50%); color: white; border: 1px solid #660000;">
                            <i class="fas fa-info-circle me-2"></i>
                            <strong>Как это работает:</strong> Создайте комнату, отправьте друзьям ссылку, вместе выбирайте видео и наслаждайтесь просмотром!
                        </div>
                    </div>
                </div>

                <!-- Особенности -->
                <div class="row g-4 mb-5">
                    <div class="col-md-4">
                        <div class="feature-card text-center text-white">
                            <div class="feature-icon">
                                <i class="fas fa-video"></i>
                            </div>
                            <h5>Синхронный просмотр</h5>
                            <p class="text-white">Пауза, перемотка и воспроизведение синхронизируются у всех участников</p>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="feature-card text-center text-white">
                            <div class="feature-icon">
                                <i class="fas fa-comments"></i>
                            </div>
                            <h5>Встроенный чат</h5>
                            <p class="text-white">Обсуждайте фильмы и сериалы прямо во время просмотра</p>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="feature-card text-center text-white">
                            <div class="feature-icon">
                                <i class="fas fa-shield-alt"></i>
                            </div>
                            <h5>Безопасно и легально</h5>
                            <p class="text-white">Используем только официальные плееры VK и RuTube</p>
                        </div>
                    </div>
                </div>

                <!-- Инструкция -->
                <div class="text-center text-white">
                    <h4 class="mb-4">
                        <i class="fas fa-play-circle me-2"></i>Начните просмотр в 3 шага
                    </h4>
                    <div class="row">
                        <div class="col-md-4">
                            <div class="mb-3">
                                <span class="rounded-circle p-3 fs-5" style="color: #8b0000;">Шаг 1.</span>
                                <h5 class="mt-2">Создайте комнату</h5>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="mb-3">
                                <span class="rounded-circle p-3 fs-5" style="color: #8b0000;">Шаг 2.</span>
                                <h5 class="mt-2">Пригласите друзей</h5>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="mb-3">
                                <span class="rounded-circle p-3 fs-5" style="color: #8b0000;">Шаг 3.</span>
                                <h5 class="mt-2">Смотрите вместе</h5>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Правая часть — лента активных комнат -->
        <div class="rooms-feed">
            <div class="rooms-header">
                <h4>
                    <i class="fas fa-users"></i>
                    Активные комнаты
                    <button class="refresh-btn ms-auto" onclick="loadActiveRooms()">
                        <i class="fas fa-sync-alt"></i> Обновить
                    </button>
                </h4>
            </div>
            <div class="rooms-list" id="roomsList">
                <div class="empty-rooms">
                    <i class="fas fa-spinner fa-spin"></i>
                    <p>Загрузка комнат...</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Контейнер для уведомлений -->
    <div id="notificationContainer"></div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const cards = document.querySelectorAll('.feature-card');
            cards.forEach((card, index) => {
                card.style.opacity = '0';
                card.style.transform = 'translateY(20px)';
                setTimeout(() => {
                    card.style.transition = 'opacity 0.5s ease, transform 0.5s ease';
                    card.style.opacity = '1';
                    card.style.transform = 'translateY(0)';
                }, index * 200);
            });

            updateUserMenu();
            loadActiveRooms();

            // Автообновление каждые 30 секунд
            setInterval(loadActiveRooms, 30000);
        });

        const roomIdInput = document.getElementById('roomId');
        if (roomIdInput) {
            roomIdInput.addEventListener('focus', function() {
                if (!this.value) {
                    const randomId = 'room-' + Math.random().toString(36).substr(2, 8);
                    this.placeholder = 'Сгенерировано: ' + randomId;
                }
            });
        }

        // ЗАГРУЗКА АКТИВНЫХ КОМНАТ 
        async function loadActiveRooms() {
            const roomsList = document.getElementById('roomsList');

            try {
                // Получаем комнаты с сервера
                const response = await fetch('/api/rooms/active');

                if (response.ok) {
                    const rooms = await response.json();
                    displayRooms(rooms);
                } else {
                    // Если API нет, показываем демо-комнаты
                    displayDemoRooms();
                }
            } catch (error) {
                console.log('API комнат недоступен, показываем демо');
                displayDemoRooms();
            }
        }

        function displayRooms(rooms) {
            const roomsList = document.getElementById('roomsList');

            if (!rooms || rooms.length === 0) {
                roomsList.innerHTML = `
                    <div class="empty-rooms">
                        <i class="fas fa-door-closed"></i>
                        <p>Нет активных комнат</p>
                        <button class="btn btn-danger btn-sm mt-2" onclick="location.href='/Home/Room'">
                            <i class="fas fa-plus"></i> Создать комнату
                        </button>
                    </div>
                `;
                return;
            }

            let html = '';
            rooms.forEach(room => {
                html += `
                    <div class="room-card" onclick="joinRoom('${room.id}')">
                        <div class="room-title">
                            <i class="fas fa-circle"></i>
                            <span>${escapeHtml(room.name || room.id)}</span>
                        </div>
                        <div class="room-info">
                            <span><i class="fas fa-video me-1"></i>${escapeHtml(room.video || 'Нет видео')}</span>
                        </div>
                        <div class="room-users">
                            <span><i class="fas fa-user me-1"></i>${room.usersCount || 1} участников</span>
                            <button class="join-btn ms-auto" onclick="event.stopPropagation(); joinRoom('${room.id}')">
                                <i class="fas fa-sign-in-alt me-1"></i>Войти
                            </button>
                        </div>
                    </div>
                `;
            });

            roomsList.innerHTML = html;
        }

        function displayDemoRooms() {
            const roomsList = document.getElementById('roomsList');

            // Демо-комнаты для примера
            const demoRooms = [
                { id: 'movie-night', name: '🎬 Киновечер', video: 'Интерстеллар', users: 4 },
                { id: 'anime-club', name: '🌸 Аниме клуб', video: 'Атака титанов', users: 3 },
                { id: 'music-videos', name: '🎵 Музыкальные клипы', video: 'Imagine Dragons', users: 2 },
                { id: 'comedy-hour', name: '😂 Комедийный час', video: 'Стендап', users: 5 }
            ];

            let html = '';
            demoRooms.forEach(room => {
                html += `
                    <div class="room-card" onclick="joinRoom('${room.id}')">
                        <div class="room-title">
                            <i class="fas fa-circle" style="color: #4CAF50;"></i>
                            <span>${room.name}</span>
                        </div>
                        <div class="room-info">
                            <span><i class="fas fa-film me-1"></i>${room.video}</span>
                        </div>
                        <div class="room-users">
                            <span><i class="fas fa-users me-1"></i>${room.users} участников</span>
                            <button class="join-btn ms-auto" onclick="event.stopPropagation(); joinRoom('${room.id}')">
                                <i class="fas fa-sign-in-alt me-1"></i>Войти
                            </button>
                        </div>
                    </div>
                `;
            });

            roomsList.innerHTML = html;
        }

        function joinRoom(roomId) {
            window.location.href = `/Home/Room?id=${roomId}`;
        }

        //  ФУНКЦИИ ПОЛЬЗОВАТЕЛЯ 
        function updateUserMenu() {
            const userMenu = document.getElementById('userMenu');
            const currentUser = localStorage.getItem('currentUser');

            if (currentUser) {
                const user = JSON.parse(currentUser);

                if (user.isGuest) {
                    userMenu.innerHTML = `
                        <div class="dropdown user-dropdown">
                            <button class="btn btn-profile dropdown-toggle" type="button" data-bs-toggle="dropdown">
                                <i class="fas fa-user-circle me-1"></i>${escapeHtml(user.username)}
                            </button>
                            <ul class="dropdown-menu dropdown-menu-dark">
                                <li><a class="dropdown-item" href="/Account/Profile">
                                    <i class="fas fa-id-card me-2"></i>Профиль
                                </a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item text-danger" href="#" onclick="logout()">
                                    <i class="fas fa-sign-out-alt me-2"></i>Выйти
                                </a></li>
                            </ul>
                        </div>
                    `;
                } else {
                    userMenu.innerHTML = `
                        <div class="dropdown user-dropdown">
                            <button class="btn btn-danger dropdown-toggle" type="button" data-bs-toggle="dropdown">
                                <i class="fas fa-user-circle me-1"></i>${escapeHtml(user.nickname || user.username)}
                            </button>
                            <ul class="dropdown-menu dropdown-menu-dark">
                                <li><a class="dropdown-item" href="/Account/Profile">
                                    <i class="fas fa-id-card me-2"></i>Мой профиль
                                </a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item text-danger" href="#" onclick="logout()">
                                    <i class="fas fa-sign-out-alt me-2"></i>Выйти
                                </a></li>
                            </ul>
                        </div>
                    `;
                }
            } else {
                userMenu.innerHTML = `
                    <a href="/Account/Login" class="btn btn-danger">
                        <i class="fas fa-sign-in-alt me-2"></i>Войти
                    </a>
                `;
            }
        }

        window.logout = function() {
            localStorage.removeItem('currentUser');
            localStorage.setItem('watchTogetherUserName', 'Гость_' + Math.floor(Math.random() * 10000));
            updateUserMenu();
            showNotification('Вы вышли из аккаунта', 'info');
            window.location.href = '/';
        }

        function showNotification(message, type = 'success') {
            const container = document.getElementById('notificationContainer');
            const notification = document.createElement('div');
            notification.className = `alert alert-${type} alert-dismissible fade show notification`;
            notification.role = 'alert';
            notification.innerHTML = `
                ${message}
                <button type="button" class="btn-close" onclick="this.parentElement.remove()"></button>
            `;
            container.appendChild(notification);

            setTimeout(() => {
                if (notification.parentElement) {
                    notification.remove();
                }
            }, 3000);
        }

        function escapeHtml(unsafe) {
            if (!unsafe) return '';
            return unsafe
                .replace(/&/g, "&amp;")
                .replace(/</g, "&lt;")
                .replace(/>/g, "&gt;")
                .replace(/"/g, "&quot;")
                .replace(/'/g, "&#039;");
        }

        const urlParams = new URLSearchParams(window.location.search);
        if (urlParams.get('registered') === 'true') {
            showNotification('Регистрация прошла успешно! Добро пожаловать!', 'success');
        } else if (urlParams.get('loggedin') === 'true') {
            showNotification('Вы успешно вошли в аккаунт!', 'success');
        }
    </script>
</body>
</html>